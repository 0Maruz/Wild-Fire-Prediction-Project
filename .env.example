# ===============================
# PROJECT
# ===============================
PROJECT_NAME=fire-risk-prediction
PROJECT_ROOT=.

# ===============================
# DATA PATHS
# ===============================
DATA_DIR=./data
RAW_DIR=./data/raw
FIRMS_DIR=./data/firms
FIRMS_PATH=./data/firms/firms_all.parquet
WEATHER_DIR=./data/weather
# Open-Meteo Archive API — no key/token. Tune if you hit HTTP 429 (rate limit):
# OPEN_METEO_MAX_WORKERS=3
# OPEN_METEO_BATCH_SIZE=1
# OPEN_METEO_APP_RETRIES=8
# OPEN_METEO_UNIT_RETRIES=5
# OPEN_METEO_FLUSH_EVERY=20
# OPEN_METEO_FINAL_RETRY_ROUNDS=15
# OPEN_METEO_RETRY_ROUND_SLEEP_BASE=45
# Prefer off-peak (Asia/Bangkok wall clock, inclusive hours): script sleeps first
# OPEN_METEO_QUIET_HOURS=2-8

# GISTDA ArcGIS REST (no key) — optional; see docs/DATA_APIS_TH.md
# Run: cd src && python fetch_gistda_hotspots.py
# Or: ./run.sh --gistda

# ===============================
# OUTPUT PATHS
# ===============================
OUTPUT_DIR=./outputs
MODEL_DIR=./outputs/models
RISKMAP_DIR=./outputs/riskmap
REPORT_DIR=./outputs/reports

# ===============================
# GRID / MODEL CONFIG
# ===============================
# Spatial resolution of the prediction grid (in degrees). Smaller = more
# precise, but cascades through the whole pipeline. After changing this you
# MUST re-run: fetch_weather.py → train.py → risk_map.py.
#   0.1   ≈ 11 km   ~500–2,000 cells   (default, fastest)
#   0.05  ≈ 5.5 km  ~2k–8k cells       (recommended sweet spot)
#   0.025 ≈ 2.7 km  ~8k–32k cells      (sharp; ~30–90 min training)
#   <0.02 → diminishing returns; FIRMS VIIRS native resolution is ~375 m
#           but the detection signal saturates well before that grid size.
GRID_SIZE=0.1
RANDOM_STATE=42
# Latest N calendar days of densified FIRMS history for train.py (0 = full range).
# MAX_TRAIN_HISTORY_DAYS=180

# ===============================
# FIRMS (NASA)
# ===============================
FIRMS_API_KEY=YOUR_FIRMS_API_KEY_HERE
FIRMS_BBOX=96,4,107,22
FIRMS_DAYS=1

# ===============================
# TRAINING
# ===============================
TEST_SIZE=0.2
N_ESTIMATORS=500
LEARNING_RATE=0.05
NUM_LEAVES=31
MIN_CHILD_SAMPLES=50

# ===============================
# BACKEND / METADATA
# ===============================
TIMEZONE=Asia/Bangkok
DATE_FORMAT=%Y-%m-%d

# ===============================
# DASHBOARD FILTERS (risk_map.py)
# ===============================
# Three sequential filters drop cells before the dashboard renders them.
# Lower thresholds = more cells shown but more noise. Tune to taste.
#
# Short-window: cells must have ≥ N fires in the last 30 days
MIN_HISTORICAL_FIRES_FOR_DISPLAY=1
# Long-window: cells must have ≥ N fires in the last LONG_HISTORY_WINDOW_DAYS
LONG_HISTORY_WINDOW_DAYS=90
MIN_LONG_HISTORICAL_FIRES=3
# Climatological fire-rate: cells must have ≥ N fire-days per year
# (annualized over the full FIRMS record). The strongest "is this place
# actually fire-prone?" filter — drops cells that the model wants to
# predict on but which have essentially never burned. 1.0 is conservative;
# try 2.0–3.0 for a tight focus on real hotspots, 0 to disable.
MIN_FIRE_DAYS_PER_YEAR=1.0

# Urban-exclusion: drop predictions that fall inside major Thai cities.
# FIRMS detects garbage burning, industrial heat, and other non-wildfire
# heat sources in cities — predicting "wildfire in central Bangkok" is
# misleading. Set URBAN_FILTER_ENABLED=false to disable. URBAN_BUFFER_KM
# adds extra exclusion distance beyond each city's hand-tuned radius.
# The list of cities is in src/urban_areas.py — edit to add/remove cities.
URBAN_FILTER_ENABLED=true
URBAN_BUFFER_KM=0.0
