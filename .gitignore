# Secrets / local env
.env
.env.local

# Python
.venv/
__pycache__/
*.pyc
*.pyo

# Editor / OS
.vscode/
.claude/
.DS_Store
*.swp

# Data — fetched at runtime via fetch_firms.py / fetch_weather.py
# (keep directory scaffolding so layout is obvious, ignore contents)
data/**
!data/
!data/raw/
!data/firms/
!data/weather/
!data/**/.gitkeep
# Thailand boundary GeoJSON — checked in because risk_map.py's country
# filter needs it; small (~1 MB) and stable.
!data/boundaries/
!data/boundaries/thailand.geojson

# Build artifacts — regenerated by train.py / risk_map.py
outputs/**
!outputs/
!outputs/models/
!outputs/features/
!outputs/metadata/
!outputs/riskmap/
!outputs/**/.gitkeep

# Misc
src.zip
Science-Project/
*.tar.gz
